# Postgres connection (Supabase: Project Settings > Database > Connection string)
# Use the pooler URI (port 6543) for the API service.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# API listen port
PORT=8080

# Optional — required for authenticated routes (/v1/requests/*)
SUPABASE_JWT_SECRET=your-jwt-secret

# Required for request image presigned URLs
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — enables API rate limiting (Upstash, local Redis, etc.)
REDIS_URL=redis://localhost:6379

# Optional — enables push notifications via Firebase Cloud Messaging
FCM_SERVER_KEY=your-fcm-legacy-server-key
