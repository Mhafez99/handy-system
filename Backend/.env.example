# DATABASE_URL (write / primary — use Supabase pooler port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional read replica / read pooler endpoint
READ_DATABASE_URL=

# API listen port
PORT=8080

# Connection pools (per API instance)
DB_POOL_SIZE=25
DB_READ_POOL_SIZE=25
DB_ACQUIRE_TIMEOUT_SECONDS=30
DB_PREWARM_POOLS=true

# Redis — required for cache + rate limiting at scale
REDIS_URL=redis://localhost:6379

# Cache TTLs (seconds)
ADMIN_STATS_CACHE_TTL_SECONDS=60
CATALOG_CACHE_TTL_SECONDS=300
WORKER_AVAILABLE_CACHE_TTL_SECONDS=20

# Optional — required for authenticated routes (/v1/requests/*)
SUPABASE_JWT_SECRET=your-jwt-secret

# Required for request image presigned URLs
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — enables push notifications via Firebase Cloud Messaging
FCM_SERVER_KEY=your-fcm-legacy-server-key
